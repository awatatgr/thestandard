# THE STANDARD — Environment Variables
# Copy this file to .env and fill in values

# =============================================================
# Supabase (Required)
# =============================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Server-side only (Cloudflare Pages environment variables)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# =============================================================
# Access Mode (Optional)
# =============================================================
# Controls how videos are accessed when Stripe is NOT configured
# Options: "public" (default) | "auth_required" | "invite"
# VITE_ACCESS_MODE=public

# =============================================================
# Bunny.net Stream (Required for video hosting)
# =============================================================
VITE_BUNNY_CDN_HOSTNAME=vz-xxx.b-cdn.net
# BUNNY_CDN_HOSTNAME=vz-xxx.b-cdn.net
# BUNNY_API_KEY=xxx
# BUNNY_LIBRARY_ID=YOUR_LIBRARY_ID

# =============================================================
# Stripe (Optional — leave empty to disable payments)
# =============================================================
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=WEBHOOK_SECRET_...
# STRIPE_MONTHLY_PRICE_ID=price_...
# STRIPE_YEARLY_PRICE_ID=price_...
