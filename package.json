{
  "name": "thestandard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "npx wrangler pages dev dist --port 8788 --compatibility-date 2024-01-01",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && npx wrangler pages deploy dist/ --project-name thestandard",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "uat": "npx playwright test e2e/uat/",
    "uat:manual": "echo '\\n  1. ブラウザで http://localhost:5173 を開く\\n  2. コンソールで以下を貼り付け:\\n\\n     const s=document.createElement(\"script\");s.src=\"/uat-inject.js\";document.head.appendChild(s);\\n\\n  3. 管理画面テストは /admin に移動してから同じコマンドを実行\\n' && vite --port 5173",
    "uat:headed": "npx playwright test e2e/uat/ --headed",
    "uat:viewer": "npx playwright test e2e/uat/viewer-flow.spec.ts",
    "uat:admin": "npx playwright test e2e/uat/admin-flow.spec.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@firstlook-uat/sdk": "^0.3.3",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.99.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hls.js": "^1.6.15",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  }
}
